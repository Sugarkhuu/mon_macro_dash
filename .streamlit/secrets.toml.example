# Copy this file to .streamlit/secrets.toml and replace the users below.
# Generate each password_hash with:
#   python tools/create_password_hash.py

[auth.users.admin]
name = "Dashboard Admin"
role = "admin"
password_hash = "replace-with-generated-password-hash"

[auth.users.viewer]
name = "Macro Viewer"
role = "viewer"
password_hash = "replace-with-generated-password-hash"
